# ShortsForge AI — LangGraph Edition
# Copy to .env and fill in your keys

# Single Google API key powers EVERYTHING: Gemini 2.0 Flash + Veo 3
GOOGLE_API_KEY=xxxxx
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json
VEDIO_GENERATION_MODEL=veo-3.0-fast-generate-001
YOUTUBE_CHANNEL_URL=https://www.youtube.com/@xxxxxxx

# Schedule (24hr, comma-separated)
POST_TIMES=11:00,19:00

# Set to true to skip YouTube upload (test mode)
DRY_RUN=false
